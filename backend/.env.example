# ─── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── CORS (comma-separated origins for production) ─
CORS_ORIGIN=https://yourdomain.com

# ─── Supabase ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
